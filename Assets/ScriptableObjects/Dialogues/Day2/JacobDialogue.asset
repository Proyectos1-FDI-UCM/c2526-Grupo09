%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bd1b51748c43e8043b83edef630f10d1, type: 3}
  m_Name: JacobDialogue
  m_EditorClassIdentifier: 
  dialogueTurnsList:
  - character: {fileID: 11400000, guid: 2a06e3355325bed4eba54ba88de3cf16, type: 2}
    dialogueLine: "Why are you crying miss? It\u2019s been so long since I\u2019ve
      seen someone here\u2026 I\u2019m scared."
  - character: {fileID: 11400000, guid: b0515a637addc26428dc0bb0046873b4, type: 2}
    dialogueLine: "Oh, it is nothing. What\u2019s your name? What are you doing here?"
  - character: {fileID: 11400000, guid: 5c15c03d2e12c1f49a32b03a4bd9cddd, type: 2}
    dialogueLine: My name is Jacob, miss. What is going on? Everyone disappeared,
      everything feels isolated now.
  - character: {fileID: 11400000, guid: 5c15c03d2e12c1f49a32b03a4bd9cddd, type: 2}
    dialogueLine: Is God punishing us?
  - character: {fileID: 11400000, guid: 7bd2146755de1cd40a43e1f48fc82523, type: 2}
    dialogueLine: "Jacob, this isn\u2019t God\u2019s doing. I can assure you of that."
  - character: {fileID: 11400000, guid: c879aef9dc6aa6248892b19a8609d66d, type: 2}
    dialogueLine: What? Then who caused this, if not God?
  - character: {fileID: 11400000, guid: b84bc399ccd85c047a921a5d9bf97124, type: 2}
    dialogueLine: An evil fiend trying to play God. Why would God punish a child?
  - character: {fileID: 11400000, guid: 2a06e3355325bed4eba54ba88de3cf16, type: 2}
    dialogueLine: "I know the weight of my actions. I know that what I\u2019ve done
      until now has been immoral\u2026 even if it was for the sake of my family."
  - character: {fileID: 11400000, guid: 2f37fd23eb690314993c9e733bfa4eca, type: 2}
    dialogueLine: "It\u2019s surprising that someone as young as you understands
      God and his principles so well. You must have been raised well."
  - character: {fileID: 11400000, guid: 995d4cde5a6a6c24693f5dc8b2d93076, type: 2}
    dialogueLine: I was born into a very religious family. Those principles were
      always present in our home.
  - character: {fileID: 11400000, guid: 5c15c03d2e12c1f49a32b03a4bd9cddd, type: 2}
    dialogueLine: "My mother was sick and we were very poor. I always put my siblings\u2019
      well-being above my own."
  - character: {fileID: 11400000, guid: 4e0658d25c6443f4f85af8e1166ecbb2, type: 2}
    dialogueLine: I gave them my food, even when my stomach growled with hunger every
      night as I went to sleep.
  - character: {fileID: 11400000, guid: 995d4cde5a6a6c24693f5dc8b2d93076, type: 2}
    dialogueLine: I begged for work just to help, even if only a little.
  - character: {fileID: 11400000, guid: c879aef9dc6aa6248892b19a8609d66d, type: 2}
    dialogueLine: "But even that wasn\u2019t enough! I had to start stealing\u2026
      hurting other people who were just as poor as us, just so we could survive!"
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: 'Don''t. Listen. '
  - character: {fileID: 11400000, guid: b0515a637addc26428dc0bb0046873b4, type: 2}
    dialogueLine: "Life hasn\u2019t been kind to you\u2026 Don\u2019t worry. This
      will all end soon."
  - character: {fileID: 11400000, guid: 96935a813e2514b409f8c3951a70ca4b, type: 2}
    dialogueLine: I hope so! What is your name, miss? I forgot to ask.
  - character: {fileID: 11400000, guid: bb224bbb551a96f4c8b1d7b7b7f3c839, type: 2}
    dialogueLine: I'm Eve.
  - character: {fileID: 11400000, guid: 995d4cde5a6a6c24693f5dc8b2d93076, type: 2}
    dialogueLine: 'No way! I met a girl yesterday. She told me that she knew someone
      who promised saving the world soon. '
  - character: {fileID: 11400000, guid: 2a06e3355325bed4eba54ba88de3cf16, type: 2}
    dialogueLine: She said that girl's name was Eve aswell! Is it you? Are we getting
      out of this? Can you help me find my family?
  - character: {fileID: 11400000, guid: b84bc399ccd85c047a921a5d9bf97124, type: 2}
    dialogueLine: L-ily?!
  - character: {fileID: 11400000, guid: fcf41119740863649a888151640fd2bb, type: 2}
    dialogueLine: "Please don\u2019t blame me, child. I must do this to help God\u2026
      and defeat the heathen who has stolen his power."
  - character: {fileID: 11400000, guid: 2a06e3355325bed4eba54ba88de3cf16, type: 2}
    dialogueLine: W-what do you mean.
  - character: {fileID: 11400000, guid: fcf41119740863649a888151640fd2bb, type: 2}
    dialogueLine: "Oh, my child\u2026"
  - character: {fileID: 11400000, guid: 995d4cde5a6a6c24693f5dc8b2d93076, type: 2}
    dialogueLine: I don't understand what you are saying, miss.
  - character: {fileID: 11400000, guid: 5c15c03d2e12c1f49a32b03a4bd9cddd, type: 2}
    dialogueLine: Please, don't cry or I'll cry too!
  - character: {fileID: 11400000, guid: fcf41119740863649a888151640fd2bb, type: 2}
    dialogueLine: Forgive me, Jacob. I promise I'll save the Earth.
  - character: {fileID: 11400000, guid: 96935a813e2514b409f8c3951a70ca4b, type: 2}
    dialogueLine: 'Of course you will! '
