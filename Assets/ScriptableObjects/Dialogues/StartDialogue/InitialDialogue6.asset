MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bd1b51748c43e8043b83edef630f10d1, type: 3}
  m_Name: InitialDialogue6
  m_EditorClassIdentifier: 
  dialogueTurnsList:
  - character: {fileID: 11400000, guid: 463fc10d7c6bbde45848383bf1128c73, type: 2}
    dialogueLine: M-me?
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: Yes.
  - character: {fileID: 11400000, guid: bb224bbb551a96f4c8b1d7b7b7f3c839, type: 2}
    dialogueLine: Recovering your power could make it possible to stop Stan's will?
  - character: {fileID: 11400000, guid: b0515a637addc26428dc0bb0046873b4, type: 2}
    dialogueLine: Would I see all my friends again?
  - character: {fileID: 11400000, guid: fcf41119740863649a888151640fd2bb, type: 2}
    dialogueLine: My mum... would I see her again?
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: Of course! Everything is possible with the power of God.
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: I just need you to pick up a flower each of the remaining days
      of Earth.
  - character: {fileID: 11400000, guid: 463fc10d7c6bbde45848383bf1128c73, type: 2}
    dialogueLine: f-flowers?
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: Flowers of Lillith. The main reason of my power loss. They consume
      all of my energy and need to get destroyed for me to be free again.
  - character: {fileID: 11400000, guid: 67ed60f38af4b474e8fb39bb24c7b0af, type: 2}
    dialogueLine: Sounds easy. I surely can help doing that.
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: I know. Just, let me take you somewhere...
