  dialogueTurnsList:
  - character: {fileID: 11400000, guid: 2e06b29a3c59d044e8f356f988f846e2, type: 2}
    dialogueLine: Good.
  - character: {fileID: 11400000, guid: 2e06b29a3c59d044e8f356f988f846e2, type: 2}
    dialogueLine: Welcome my dear child to the sacred land.
  - character: {fileID: 11400000, guid: 463fc10d7c6bbde45848383bf1128c73, type: 2}
    dialogueLine: ...
  - character: {fileID: 11400000, guid: 67ed60f38af4b474e8fb39bb24c7b0af, type: 2}
    dialogueLine: Thank you for everything Lily.
  - character: {fileID: 11400000, guid: 2f37fd23eb690314993c9e733bfa4eca, type: 2}
    dialogueLine: "Though our paths must diverge now, I\u2019ll always remember you."
  - character: {fileID: 11400000, guid: b0515a637addc26428dc0bb0046873b4, type: 2}
    dialogueLine: "I\u2019ll miss you so much."
  - character: {fileID: 11400000, guid: e87ed0745fc98bd4b898847d672cbb01, type: 2}
    dialogueLine: "Don\u2019t worry Eve, I\u2019ll be fine. After all, death is my
      only salvation now, the only way in which I could be redeemed."
  - character: {fileID: 11400000, guid: 93c580ac30e7bd54b84db33920e85a6f, type: 2}
    dialogueLine: Take care of yourself.
  - character: {fileID: 11400000, guid: e87ed0745fc98bd4b898847d672cbb01, type: 2}
    dialogueLine: I love you Eve.
  - character: {fileID: 11400000, guid: 67ed60f38af4b474e8fb39bb24c7b0af, type: 2}
    dialogueLine: ...
  - character: {fileID: 11400000, guid: 2f37fd23eb690314993c9e733bfa4eca, type: 2}
    dialogueLine: Farewell, Lily.
