  dialogueTurnsList:
  - character: {fileID: 11400000, guid: 93c580ac30e7bd54b84db33920e85a6f, type: 2}
    dialogueLine: ...
  - character: {fileID: 11400000, guid: e87ed0745fc98bd4b898847d672cbb01, type: 2}
    dialogueLine: "Eve\u2026"
  - character: {fileID: 11400000, guid: e87ed0745fc98bd4b898847d672cbb01, type: 2}
    dialogueLine: "Don\u2019t be too hard on yourself."
  - character: {fileID: 11400000, guid: 1e845b191a59137458fd74ddf8544cf4, type: 2}
    dialogueLine: You had no idea about all this!
  - character: {fileID: 11400000, guid: 817ef739fb283a84995207a6f9e76224, type: 2}
    dialogueLine: This is not what I wanted. I just wanted to know why I ended up
      here.
  - character: {fileID: 11400000, guid: b0515a637addc26428dc0bb0046873b4, type: 2}
    dialogueLine: I spent my whole life thinking I had been a good christian.
  - character: {fileID: 11400000, guid: fcf41119740863649a888151640fd2bb, type: 2}
    dialogueLine: But now I know the answer.
  - character: {fileID: 11400000, guid: 1e845b191a59137458fd74ddf8544cf4, type: 2}
    dialogueLine: ...
  - character: {fileID: 11400000, guid: b0515a637addc26428dc0bb0046873b4, type: 2}
    dialogueLine: "\u2026 Lily \u2026 I \u2026"
