--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bd1b51748c43e8043b83edef630f10d1, type: 3}
  m_Name: BossDialogue
  m_EditorClassIdentifier: 
  dialogueTurnsList:
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: YOU DAMNED CHILD
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: "Couldn\u2019t you just obey my orders?"
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: "Look at what you\u2019ve caused with your nonsense!"
  - character: {fileID: 11400000, guid: 7bd2146755de1cd40a43e1f48fc82523, type: 2}
    dialogueLine: What?
  - character: {fileID: 11400000, guid: b84bc399ccd85c047a921a5d9bf97124, type: 2}
    dialogueLine: Where are we?
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: Eve
  - character: {fileID: 11400000, guid: 7bd2146755de1cd40a43e1f48fc82523, type: 2}
    dialogueLine: Yes?
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: "I lied to you. I\u2019ve been lying the whole time."
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: I am neither Agnus Dei nor Jesus.
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: I am one of those devilish creatures you humans hate.
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: "I am nothing but a demon. The most powerful of them all if I\u2019m
      allowed to say it."
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: God banished me to this den of filth and decay and stripped me
      from all my powers.
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: But now, with those damned flowers gone, I can claim my powers
      back.
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: And ultimately, take revenge for all these years of horror and
      despair.
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: So, with your permission miss, could you please
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: GIVE ME THE FUCKING FLOWER!!!!!
