MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bd1b51748c43e8043b83edef630f10d1, type: 3}
  m_Name: BlockingEnemy
  m_EditorClassIdentifier: 
  dialogueTurnsList:
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: You are getting better at this, Eve!
  - character: {fileID: 11400000, guid: b0515a637addc26428dc0bb0046873b4, type: 2}
    dialogueLine: I-I'm so scared...
  - character: {fileID: 11400000, guid: fcf41119740863649a888151640fd2bb, type: 2}
    dialogueLine: I miss my mum.
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: Just do what I say, and everything will go back to what it used
      to be.
  - character: {fileID: 11400000, guid: 463fc10d7c6bbde45848383bf1128c73, type: 2}
    dialogueLine: Do you think Lily is gonna be alright?
  - character: {fileID: 11400000, guid: 2f37fd23eb690314993c9e733bfa4eca, type: 2}
    dialogueLine: 'Shouldn''t she come with us? '
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: Just focus on yourself and on me for a while, and everything is
      gonna be fine.
  - character: {fileID: 11400000, guid: f744c7f0aa979e14a931ddcfb4fb1faf, type: 2}
    dialogueLine: C'mon, my flower is pretty much near here!
  - character: {fileID: 11400000, guid: 2f37fd23eb690314993c9e733bfa4eca, type: 2}
    dialogueLine: Yeah, fine! Let's save the world, Agnus.
